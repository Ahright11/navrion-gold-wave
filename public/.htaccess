# Serve index.html for / (must come before WP's DirectoryIndex fallback)
DirectoryIndex index.html index.php

# SPA routing — any non-file request falls through to index.html
RewriteEngine On
RewriteBase /
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

# Long-cache hashed build assets
<FilesMatch "\.(js|css|woff2?|webp|png|jpe?g|mp4|svg)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Never cache index.html — new deploys take effect immediately
<FilesMatch "^index\.html$">
  Header set Cache-Control "no-cache, must-revalidate"
</FilesMatch>

# Explicit MIME for WebP (older Apaches sometimes miss it)
AddType image/webp .webp

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/plain
</IfModule>
